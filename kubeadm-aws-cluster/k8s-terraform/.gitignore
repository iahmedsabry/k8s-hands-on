# Terraform files with sensitive data
terraform.tfvars
*.tfvars
*.tfvars.json
!terraform.tfvars.example

# Terraform state files
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Plan files
*.tfplan
tfplan

# Crash logs
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.auto.tfvars
*.auto.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
